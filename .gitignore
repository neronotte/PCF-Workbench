# Dependencies
node_modules/

# Build output
dist/
out/

# IDE
.vs/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Env
.env
.env.local

# Debug
*.log
npm-debug.log*

# Temp
*.tmp
debug_*.py
debug_*.png
generate_*.py

# Vite cache
.vite/

# Claude Code settings
.claude/

# Design & docs (not part of harness source)
design/
*.docx
*.pptx
screenshots/
*.customization
DEPLOYMENT_ROADMAP.md
program-dashboard.html

# Sample PCFs (commit sources only)
samples/**/out/
samples/**/obj/
samples/**/bin/
samples/**/node_modules/
samples/**/generated/

# Playwright test artifacts (failure screenshots, traces)
harness/test-results/
harness/playwright-report/
harness/__visual__/last-failure.png

# M2 auth/CORS spike (disposable, do not commit)
.spike/

# M9 — extracted controls cache (disposable, never commit)
samples/_extracted/
harness/.pcf-extracted/

# M9.P2 — on-demand Fluent UMD cache (npm install + esbuild output, never commit)
harness/.fluent-cache/

# Playwright MCP scratch (interactive browser session artifacts)
.playwright-mcp/

# MAI — AI build loop reports (regenerated on every run)
pcf-loop-reports/
harness/pcf-loop-reports/
samples/*/loop-report/
samples/MAILoopDemo/out/

# M11 — Vitest coverage reports
harness/coverage/

# M12 — npm publish staging (recreated by `npm run build:publish`)
harness/publish-staging/

# TypeScript incremental build artifacts
harness/tsconfig.tsbuildinfo
harness/*.tsbuildinfo

# Stray transpiled .js emitted into src/ by `tsc -b` (we use Vite at runtime
# and esbuild at publish — the harness `noEmit: true` setting still leaks if
# the tsbuildinfo cache is dirty; never commit these)
harness/src/**/*.js
harness/bin/*.js
!harness/bin/pcf-harness.js


