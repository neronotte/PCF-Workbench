{
  "name": "pcf-harness",
  "version": "0.1.0",
  "description": "Enhanced PCF development harness with offline simulation, network conditioning, and performance monitoring",
  "type": "module",
  "bin": {
    "pcf-harness": "./bin/pcf-harness.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "harness": "tsx bin/pcf-harness.ts"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.56.0",
    "@fluentui/react-icons": "^2.0.258",
    "commander": "^12.1.0",
    "fast-xml-parser": "^4.5.0",
    "html2canvas": "^1.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
