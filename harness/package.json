{
  "name": "pcf-workbench",
  "version": "1.0.0",
  "description": "PCF Workbench — a full-featured development environment for Power Apps Component Framework controls",
  "type": "module",
  "bin": {
    "pcf-harness": "./bin/pcf-harness.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "harness": "tsx bin/pcf-harness.ts",
    "conformance:diff": "tsx scripts/conformance-diff.ts"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.2",
    "@azure/msal-node-extensions": "^5.2.2",
    "@fluentui/react-components": "^9.73.8",
    "@fluentui/react-icons": "^2.0.327",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "fast-xml-parser": "^5.7.0",
    "html2canvas": "^1.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@fluentui/font-icons-mdl2": "^8.5.73",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "@types/powerapps-component-framework": "^1.3.18",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/xrm": "^9.0.94",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
