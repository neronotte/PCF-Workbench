{
  "name": "@pcfworkbench/cli",
  "version": "1.0.2",
  "description": "PCF dev harness + AI build loop for Power Apps Component Framework controls. Run your PCFs locally against shimmed ComponentFramework.Context APIs without a Dataverse round-trip.",
  "type": "module",
  "license": "MIT",
  "author": "jaduplesms",
  "homepage": "https://github.com/jaduplesms/PCF-Workbench#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaduplesms/PCF-Workbench.git"
  },
  "bugs": {
    "url": "https://github.com/jaduplesms/PCF-Workbench/issues"
  },
  "keywords": [
    "pcf",
    "powerapps",
    "power-apps",
    "dataverse",
    "component-framework",
    "harness",
    "testing",
    "vite",
    "ai",
    "ci"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "pcfworkbench": "./bin/pcfworkbench.js"
  },
  "files": [
    "bin/pcfworkbench.js",
    "src/",
    "index.html",
    "tsconfig.json",
    "docs/ai-loop-report.schema.json",
    "docs/ai-build-loop.md",
    "docs/ai-loop-skill.md",
    "docs/examples/pcf-loop.yml",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "harness": "tsx bin/pcfworkbench.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build:publish": "node scripts/build-publish.mjs",
    "conformance:diff": "tsx scripts/conformance-diff.ts"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.2",
    "@azure/msal-node-extensions": "^5.2.2",
    "@fluentui/react-components": "^9.73.8",
    "@fluentui/react-icons": "^2.0.327",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^6.0.2",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "esbuild": "^0.28.1",
    "fast-xml-parser": "^5.7.0",
    "html2canvas": "^1.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^8.0.16",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@fluentui/font-icons-mdl2": "^8.5.73",
    "@types/node": "^25.9.3",
    "@types/powerapps-component-framework": "^1.3.18",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/xrm": "^9.0.92",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
