{
  "name": "pcf-workbench",
  "version": "1.0.0",
  "description": "PCF Workbench — a full-featured development environment for Power Apps Component Framework controls",
  "type": "module",
  "bin": {
    "pcf-harness": "./bin/pcf-harness.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "harness": "tsx bin/pcf-harness.ts",
    "conformance:diff": "tsx scripts/conformance-diff.ts"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.2",
    "@azure/msal-node-extensions": "^5.2.2",
    "@fluentui/react-components": "^9.73.8",
    "@fluentui/react-icons": "^2.0.258",
    "commander": "^12.1.0",
    "fast-xml-parser": "^4.5.0",
    "html2canvas": "^1.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "@types/powerapps-component-framework": "^1.3.18",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/xrm": "^9.0.92",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
